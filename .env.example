NODE_ENV=development
PORT=3002

# Internal API protection. Required in production.
AI_SERVICE_KEY=change-me

# Local Docker Compose database uses pgvector.
DATABASE_URL=postgres://crm_ai:crm_ai@localhost:5433/crm_ai_chatbot
DATABASE_SSL=false

# Hugging Face Inference Providers
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_PROVIDER=
HF_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct-1M:preferred
HF_EMBEDDING_MODEL=thenlper/gte-large
HF_MAX_TOKENS=450
HF_TEMPERATURE=0.2
HF_REQUEST_TIMEOUT_MS=10000

# RAG behavior
RETRIEVAL_TOP_K=5
MIN_CONFIDENCE=0.55
CHUNK_SIZE_MESSAGES=8

# Optional one-off importer from the existing CRM database into this AI service.
# Keep this pointed at the old CRM database, not the pgvector database above.
CRM_DATABASE_URL=postgres://postgres:password@localhost:5432/crm_astronacci
AI_SERVICE_BASE_URL=http://localhost:3002
CRM_INGEST_TENANT_ID=astronacci
CRM_INGEST_CHANNEL=whatsapp
CRM_INGEST_LIMIT_CHATS=50
CRM_INGEST_SINCE=
CRM_INGEST_CUSTOMER_PHONE=
CRM_INGEST_MESSAGE_TYPES=TEXT
CRM_INGEST_INCLUDE_BOT=false
CRM_INGEST_EXCLUDE_SYSTEM=true
CRM_INGEST_DRY_RUN=false
CRM_INGEST_DELAY_MS=0
CRM_EXPORT_JSONL_PATH=
